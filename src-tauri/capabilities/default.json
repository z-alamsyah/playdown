{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "opener:default",
    "dialog:default",
    "dialog:allow-confirm",
    "store:default",
    "clipboard-manager:allow-write-text"
  ]
}
